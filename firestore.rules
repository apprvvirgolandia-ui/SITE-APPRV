rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: settings
    // Document ID: main
    // Fields:
    //   - name: string
    //   - shortName: string
    //   - cnpj: string
    //   - foundationDate: string
    //   - address: string
    //   - phone: string
    //   - whatsapp: string
    //   - email: string
    //   - facebook: string
    //   - instagram: string
    //   - googleMapsUrl: string
    //   - logoUrl: string
    //   - pulpLogoUrl: string
    //   - pulpLogoSecondaryUrl: string
    //   - pulpLogoCircularUrl: string
    //   - partnerLogoUrl: string
    //   - products: array of Product objects
    //   - storeProducts: array of Product objects
    //   - news: array of NewsItem objects
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "apprvvirgolandia@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /settings/main {
      allow read: if true; // Public read access for site config
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
